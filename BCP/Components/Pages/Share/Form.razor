@using BCP.Models

<!-- Secção: Informações Básicas -->
<div class="card mb-4">
    <div class="card-header bg-primary text-white">
        <h5 class="mb-0">Informações Básicas</h5>
    </div>
    <div class="card-body">
        <div class="row g-4">
            
            <!-- Título -->
            <div class="col-12 col-md-8">
                <label class="form-label fw-bolder">Título</label>
                <InputText @bind-Value="Book.Title" class="form-control"/>
                <ValidationMessage For="@(() => Book.Title)" class="text-danger small"/>
            </div>

            <!-- ISBN -->
            <div class="col-12 col-md-2">
                <label class="form-label fw-bolder">ISBN</label>
                <InputText @bind-Value="Book.ISBN" class="form-control" placeholder="9780000000000"/>
                <ValidationMessage For="() => Book.ISBN" class="text-danger small"/>
            </div>

            <!-- Formato -->
            <div class="col-12 col-md-2">
                <label class="form-label fw-bolder">Formato</label>
                <InputSelect @bind-Value="Book.Format" class="form-select">
                    @foreach (var format in OptionForm.Format)
                    {
                        <option value="@format">@format</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => Book.Format" class="text-danger small"/>
            </div>
        </div>
    </div>
</div>

<!-- Secção: Autoria e Classificação -->
<div class="card mb-4">
    <div class="card-header bg-success text-white">
        <h5 class="mb-0">Autoria e Classificação</h5>
    </div>
    <div class="card-body">
        <div class="row g-4">
            
            <!-- Autor -->
            <div class="col-12 col-md-5">
                <label class="form-label fw-bolder">Autor</label>
                <InputText @bind-Value="Book.Author" class="form-control"/>
                <ValidationMessage For="@(() => Book.Author)" class="text-danger small"/>
            </div>

            <!-- Assunto -->
            <div class="col-12 col-md-5">
                <label class="form-label fw-bolder">Assunto</label>
                <InputText @bind-Value="Book.Subject" class="form-control"/>
                <ValidationMessage For="() => Book.Subject" class="text-danger small"/>
            </div>

            <!-- Género -->
            <div class="col-12 col-md-2">
                <label class="form-label fw-bolder">Género</label>
                <InputSelect @bind-Value="Book.Gender" class="form-select">
                    @foreach (var gender in OptionForm.Gender)
                    {
                        <option value="@gender">@gender</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => Book.Gender" class="text-danger small"/>
            </div>
        </div>
    </div>
</div>

<!-- Secção: Dados de Publicação -->
<div class="card mb-4">
    <div class="card-header bg-info text-white">
        <h5 class="mb-0">Dados de Publicação</h5>
    </div>
    <div class="card-body">
        <div class="row g-4">
            
            <!-- Editora -->
            <div class="col-12 col-md-8">
                <label class="form-label fw-bolder">Editora</label>
                <InputText @bind-Value="Book.Publisher" class="form-control"/>
                <ValidationMessage For="() => Book.Publisher" class="text-danger small"/>
            </div>
            
            <!-- Edição -->
            <div class="col-6 col-md-2">
                <label class="form-label fw-bolder">Edição</label>
                <InputNumber @bind-Value="Book.Edition" class="form-control" min="1"/>
                <ValidationMessage For="() => Book.Edition" class="text-danger small"/>
            </div>
            
            <!-- Ano de Publicação -->
            <div class="col-6 col-md-2">
                <label class="form-label fw-bolder">Ano de Publicação</label>
                <InputText @bind-Value="Book.PublicationYear" class="form-control"/>
                <ValidationMessage For="() => Book.PublicationYear" class="text-danger small"/>
            </div>
        </div>
    </div>
</div>

<!-- Secção: Descrição, Observação e Proprietário -->
<div class="card mb-4">
    <div class="card-header bg-warning text-dark">
        <h5 class="mb-0">Descrição e Observação</h5>
    </div>
    <div class="card-body">
        <div class="row g-4">
            
            <!-- Descrição -->
            <div class="col-12">
                <label class="form-label fw-bolder">Descrição</label>
                <InputTextArea @bind-Value="Book.Description" class="form-control" rows="5" 
                               placeholder="Descrição do conteúdo do livro..."/>
                <ValidationMessage For="() => Book.Description" class="text-danger small"/>
            </div>

            <!-- Observação -->
            <div class="col-12">
                <label class="form-label fw-bolder">Observação</label>
                <InputTextArea @bind-Value="Book.Note" class="form-control" rows="3"
                               placeholder="Observação adicional, estado do livro, entre outros..."/>
                <ValidationMessage For="() => Book.Note" class="text-danger small"/>
            </div>

            <!-- Proprietário -->
            <div class="col-2 col-md-2">
                <label class="form-label fw-bolder">Proprietário</label>
                <InputSelect @bind-Value="Book.Owner" class="form-select">
                    @foreach(var owner in OptionForm.Owner)
                    {
                        <option value="@owner">@owner</option>
                    }
                </InputSelect>
                <ValidationMessage For="() => Book.Owner" class="text-danger small"/>
            </div>
        </div>
    </div>
</div>

@code {
    [Parameter] public Book Book { get; set; } = new();
}