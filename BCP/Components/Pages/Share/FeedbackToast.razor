@if (!string.IsNullOrEmpty(Message))
{
    <div class="toast-container position-fixed bottom-0 justify-content-start p-2">
        <div class="toast show @(Success ? "bg-success" : "bg-danger") text-white" role="alert">
            <div class="toast-body">
                @Message
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Success { get; set; }
    [Parameter] public string? Message { get; set; }
}