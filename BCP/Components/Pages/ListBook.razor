@page "/"
@rendermode InteractiveServer

@using BCP.Components.Pages.Share
@using BCP.Models
@using BCP.Services
@using Microsoft.AspNetCore.Components.QuickGrid

@inject BookOperation Operation

<PageTitle>Catálogo de Livros</PageTitle>

<div class="container-fluid py-4">
    <div class="card mb-4">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h6 class="mb-0">Livros Catalogados</h6>

            <div>
                <input type="search" @bind-value="_searchTerm" @bind-value:event="oninput"
                       @onkeyup="FilterBook" class="form-control" placeholder="pesquisar..."/>
            </div>
        </div>

        @if (!_book.Any())
        {
            <div class="d-flex justify-content-center align-items-center p-4">
                <div class="alert alert-info d-flex gap-2 mb-0" role="alert">
                    <span>Nenhum livro catalogado.</span>
                </div>
            </div>
        }
        else
        {
            <div class="card-body">
                <div class="table-responsive">
                    <QuickGrid Items="@_filterBook.AsQueryable()" Pagination="@_state" Class="table table-borderless align-middle">
                        <PropertyColumn Property="@(b => b.Title)" Title="Título" Sortable="true"/>
                        <PropertyColumn Property="@(b => b.Author)" Title="Autor" Sortable="true"/>
                        <PropertyColumn Property="@(b => b.Subject)" Title="Assunto" Sortable="true"/>
                        <PropertyColumn Property="@(b => b.Gender)" Title="Género" Sortable="true"/>
                        <TemplateColumn>
                            <a href=@($"/dados_livro/{context.Id}") class="btn btn-info btn-sm">Detalhes</a>
                        </TemplateColumn>
                    </QuickGrid>
                </div>
                <Paginator State="@_state" />
            </div>
        }
    </div>
</div>

<FeedbackToast Success="@_success" Message="@_message"/>


@code {
    private List<Book> _book = [];
    private List<Book> _filterBook = [];
    private string? _searchTerm;
    private string? _message;
    private bool _success;
    private readonly PaginationState _state = new() { ItemsPerPage = 20 };

    /// <summary>
    /// Carrega a lista de livros do catálogo ao inicializar a página/componente.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        try
        {
            _filterBook = _book = await Operation.ListBookAsync();
        }
        catch
        {
            _success = false;
            _message = "Não foi possível carregar a lista de livros.";
            _book = [];
            _filterBook = [];
        }
    }
    
    /// <summary>
    /// Filtra a lista de livros com base no termo de pesquisa atual.
    /// </summary>
    private void FilterBook()
    {
        if (string.IsNullOrWhiteSpace(_searchTerm))
        {
            _filterBook = _book.ToList();
            return;
        }

        _filterBook = _book.Where(book => 
            book.Title?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) == true ||
            book.Author?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) == true ||
            book.Subject?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) == true ||
            book.Gender?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) == true ).ToList();
    }
}
