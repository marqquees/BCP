@page "/"
@using BCP.Components.Pages.Share
@using BCP.Models
@using BCP.Services
@using Microsoft.AspNetCore.Components.QuickGrid
@rendermode InteractiveServer

@inject BookOperation Operation

<PageTitle>Catálogo de Livros</PageTitle>

<div class="container-fluid py-4">
    <div class="card mb-4">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h6 class="mb-0">
                Livros Catalogados
                <span class="badge bg-light text-primary ms-1">@_book.Count</span>
            </h6>

            <div>
                <input type="text"
                       class="form-control form-control-sm"
                       placeholder="pesquisar..."
                       @bind-value="_searchTerm"
                       @bind-value:event="oninput"
                       @onkeyup="FilterBook"/>
            </div>
        </div>

        @if (!_book.Any())
        {
            <div class="d-flex justify-content-center align-items-center p-4">
                <div class="alert alert-info d-flex gap-2 mb-0" role="alert">
                    <span>Nenhum livro catalogado.</span>
                </div>
            </div>
        }
        else
        {
            <div class="card-body">
                <div class="table-responsive">
                    <QuickGrid Items="_filterBook.AsQueryable()" Pagination="_pagination"
                               Class="table table-hover align-middle">
                        <PropertyColumn Property="@(e => e.Title)" Title="Título" Sortable="true"/>
                        <PropertyColumn Property="@(e => e.Author)" Title="Autor" Sortable="true"/>
                        <PropertyColumn Property="@(e => e.Subject)" Title="Assunto" Sortable="true"/>
                        <PropertyColumn Property="@(e => e.Gender)" Title="Género" Sortable="true"/>
                        <TemplateColumn Title="Ações">
                            <a href="/detalhes_livro/@context.Id" class="btn btn-info btn-sm">
                                Detalhes
                            </a>
                        </TemplateColumn>
                    </QuickGrid>
                    <Paginator State="_pagination"/>
                </div>
            </div>
        }
    </div>
</div>

<FeedbackToast Message="@_message" Success="@_success"/>


@code {
    private List<Book> _book = [];
    private List<Book> _filterBook = [];
    private string? _searchTerm;
    private string? _message;
    private bool _success;
    private readonly PaginationState _pagination = new() { ItemsPerPage = 20 };

    /// <summary>
    /// Carrega a lista de livros do catálogo ao inicializar a página/componente.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        try
        {
            _filterBook = _book = await Operation.ListBookAsync();
        }
        catch
        {
            _message = "Não foi possível carregar a lista de livros.";
            _success = false;
            _book = [];
            _filterBook = [];
        }
    }
    
    /// <summary>
    /// Filtra a lista de livros com base no termo de pesquisa inserido pelo usuário,
    /// atualizando a exibição dos resultados.
    /// </summary>
    private void FilterBook()
    {
        _filterBook = Operation.FilterBook(_book, _searchTerm);
    }
}
