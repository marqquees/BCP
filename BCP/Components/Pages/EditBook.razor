@page "/editar-livro/{id:int}"
@rendermode InteractiveServer

@using BCP.Components.Pages.Share
@using BCP.Models
@using BCP.Services

@inject BookOperation Operation
@inject NavigationManager Navigation

<PageTitle>Editar Livro</PageTitle>

@if (_book is null)
{
    <div class="d-flex justify-content-center p-4">
        <div class="spinner-border text-primary" role="status">
            <span class="visually-hidden">Carregando...</span>
        </div>
    </div>
}
else
{
    <div class="container-fluid py-4">
        <div class="row justify-content-center">
            <div class="col-lg-11 col-xl-12">
                <div class="mb-4">
                    <h1 class="h3 mb-2">Edite os dados do Livro</h1>
                    @*<p class="text-muted">Atualize as informações do livro <strong>@_book.Title</strong></p>*@
                </div>

                <EditForm Model="_book" OnValidSubmit="UpdateDataBook" FormName="editBookForm" class="needs-validation">
                    <DataAnnotationsValidator/>

                    <Form Book="_book"></Form>

                    <!-- Botões de Ação -->
                    <div class="d-flex flex-wrap gap-2 justify-content-end">

                        <!-- Cancelar -->
                        <button type="button" class="btn btn-outline-secondary" @onclick="CancelEdit">
                            <i class="bi bi-arrow-left"></i> Cancelar
                        </button>

                        <!-- Atualizar -->
                        <button type="submit" class="btn btn-success">
                            Atualizar
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<InfoModal Message="@_message" Success="@_success"/>

@code {
    [Parameter] public int Id { get; set; }
    
    private Book? _book;
    private string? _message;
    private bool _success;

    /// <summary>
    /// Carrega os dados do livro para edição com base no ID fornecido na URL.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        try
        {
            _book = await Operation.FindBookByIdAsync(Id);
        }
        catch (Exception error)
        {
            _message = $"Erro ao carregar os dados do livro {_book?.Title}. " +
                       $"\n Erro: {error.Message}";
            _success = false;
        }
    }

    /// <summary>
    /// Atualiza os dados do livro na base de dados e exibe uma mensagem de sucesso ou erro.
    /// </summary>
    private async Task UpdateDataBook()
    {
        if (_book is null) return;

        try
        {
            await Operation.UpdateDataBookAsync(_book);

            _message = "Atualizado!";
            _success = true;
            
            await Task.Delay(2000);
            Navigation.NavigateTo("/");
        }
        catch (Exception error)
        {
            _message = $"Erro ao atualizar o livro {_book.Title}." +
                       $"\nErro: {error.Message}";
            _success = false;
        }
        finally
        {
            _message = string.Empty;
            StateHasChanged();
        }    
    }

    /// <summary>
    /// Navega de volta para a página inicial sem salvar as alterações feitas no livro.
    /// </summary>
    private void CancelEdit()
    {
        Navigation.NavigateTo("/");
    }
}