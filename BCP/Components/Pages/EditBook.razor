@page "/editar_livro/{Id:int}"
@rendermode InteractiveServer

@using BCP.Components.Pages.Share
@using BCP.Models
@using BCP.Services

@inject BookOperation Operation
@inject NavigationManager Navigation

<PageTitle>Editar Livro</PageTitle>

@if (_book is null)
{
    <div class="d-flex justify-content-center align-items-center p-4">
        <div class="alert alert-warning d-flex gap-2 mb-0" role="alert">
            <span>Livro não encontrado.</span>
        </div>
    </div>
}
else
{
    <div class="container-fluid py-4">
        <div class="row justify-content-center">
            <div class="col-lg-11 col-xl-12">
                <EditForm Model="@_book" OnValidSubmit="@UpdateDataBook" class="needs-validation">
                    <DataAnnotationsValidator/>
                    <Form Book="@_book"></Form>
                    
                    <!-- Botões de Ação -->
                    <div class="d-flex flex-wrap gap-2 justify-content-end">
                        
                        <!-- Cancelar -->
                        <button type="button" class="btn btn-outline-secondary" @onclick="CancelEdit">Cancelar</button>

                        <!-- Atualizar -->
                        <button type="submit" class="btn btn-success">Atualizar</button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

<FeedbackToast Success="@_success" Message="@_message"/>

@code {
    [Parameter] public int Id { get; set; }
    
    private Book? _book;
    private string? _message;
    private bool _success;

    /// <summary>
    /// Carrega os dados do livro para edição com base no ID fornecido na URL.
    /// </summary>
    protected override async Task OnInitializedAsync()
    {
        try
        {
            _book = await Operation.FindBookByIdAsync(Id);
        }
        catch
        {
            _success = false;
            _message = "Erro ao carregar os dados.";
        }
    }

    /// <summary>
    /// Atualiza os dados do livro na base de dados e exibe uma mensagem de sucesso ou erro.
    /// </summary>
    private async Task UpdateDataBook()
    {
        if (_book is null) return;
        try
        {
            await Operation.UpdateDataBookAsync(_book);

            _success = true;
            _message = "Os dados foram atualizados!";
            
            await Task.Delay(1000);
            Navigation.NavigateTo("/");
        }
        catch
        {
            _success = false;
            _message = "Não foi possível atualizar os dados.";
        }
    }

    /// <summary>
    /// Navega de volta para a página inicial sem salvar as alterações feitas no livro.
    /// </summary>
    private void CancelEdit()
    {
        Navigation.NavigateTo("/");
    }
}