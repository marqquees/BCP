@rendermode InteractiveServer

@page "/add_book"

@using BCP.Components.Pages.Share
@using BCP.Models
@using BCP.Services

@inject BookOperation Operation
@inject IsbnLookup IsbnLookup

<PageTitle>Adicionar Livro</PageTitle>

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-11 col-xl-12">
            <!-- Secção: Preenchimento Automático por ISBN -->
            <div class="card mb-4">
                <div class="card-body bg-light">
                    <label class="form-label fw-bold">Preenchimento Automático</label>
                    <div class="input-group">
                        <input type="text"
                               class="form-control"
                               placeholder="Insira um ISBN válido para preencher os restantes dados no formulário."
                               @bind="_book.ISBN"/>

                        <button class="btn btn-secondary" type="button" @onclick="AutoFillByIsbn" disabled="@_isLoading">
                            @if (_isLoading)
                            {
                                <span class="spinner-border spinner-border-sm"></span>
                            }
                            else
                            {
                                <span>Consultar ISBN</span>
                            }
                        </button>
                    </div>
                </div>
            </div>

            <!-- Secção: Formulário de Adição de Livro -->
            <EditForm Model="@_book" OnValidSubmit="@SubmitBook" class="needs-validation">
                <DataAnnotationsValidator/>
                <BookForm Book="@_book"/>

                <!-- Secção: Botões de Ação -->
                <div class="d-flex gap-2 justify-content-end">
                    <!-- Limpar os Dados do Formulário -->
                    <button type="button" class="btn btn-outline-secondary" @onclick="ClearFormData">Limpar</button>

                    <!-- Adicionar -->
                    <button type="submit" class="btn btn-primary">Adicionar</button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

<FeedbackToast Success="@_success" Message="@_message"/>

@code {
    private Book _book = new();
    private string? _message;
    private bool _success;
    private bool _isLoading;

    /// <summary>
    /// Método para preencher automaticamente os dados do livro com base no ISBN fornecido.
    /// Ele verifica se o ISBN é válido, tenta buscar os dados usando o serviço de consulta e atualiza o modelo do livro.
    /// Se o ISBN for inválido ou se os dados não puderem ser encontrados, exibe mensagens de erro apropriadas para o
    /// utilizador.
    /// </summary>
    private async Task AutoFillByIsbn()
    {
        if (string.IsNullOrWhiteSpace(_book.ISBN))
        {
            _success = false;
            _message = "Por favor, insira um ISBN válido.";
            return;
        }

        try
        {
            _isLoading = true;
            StateHasChanged();

            var success = await IsbnLookup.FillBookDataFromIsbnAsync(_book);
            if (!success)
            {
                _success = false;
                _message = "Não foi possível encontrar dados para o ISBN fornecido.";
            }
        }
        catch
        {
            _success = false;
            _message = "Ocorreu um erro ao consultar o ISBN. Tente novamente.";
        }
        finally
        {
            _isLoading = false;
            StateHasChanged();
        }
    }

    /// <summary>
    /// Método para submeter os dados do formulário de adição de um livro ao catálogo.
    /// Ele tenta adicionar o livro usando a operação fornecida e captura quaisquer erros que possam ocorrer,
    /// exibindo mensagens apropriadas para o utilizador.
    /// </summary>
    private async Task SubmitBook()
    {
        try
        {
            await Operation.AddBookAsync(_book);

            _success = true;
            _message = "Livro adicionado!";

            ClearFormData();
        }
        catch (InvalidOperationException error)
        {
            _success = false;
            _message = error.Message;
        }
        catch
        {
            _success = false;
            _message = "Ocorreu um erro inesperado. Tente novamente.";
        }
    }

    /// <summary>
    /// Método para limpar os dados do formulário,
    /// restaurando o modelo do livro para um novo objeto vazio e atualizando a interface do utilizador.
    /// </summary>
    private void ClearFormData()
    {
        _book = new Book();
        StateHasChanged();
    }
}