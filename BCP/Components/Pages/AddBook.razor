@page "/adicionar-livro"
@rendermode InteractiveServer

@using BCP.Components.Pages.Share
@using BCP.Models
@using BCP.Services

@inject BookOperation Operation

<PageTitle>Adicionar Livro</PageTitle>

<div class="container-fluid py-4">
    <div class="row justify-content-center">
        <div class="col-lg-11 col-xl-12">
            <EditForm Model="_book" OnValidSubmit="SubmitAddBook" FormName="addBookForm" class="needs-validation">
                <DataAnnotationsValidator />

                <Form Book="_book"></Form>
                    
                <!-- Seção: Botões de Ação -->
                <div class="d-flex gap-2 justify-content-end">
                        
                    <!-- Limpar os Dados -->
                    <button type="button" class="btn btn-outline-secondary" @onclick="ClearFormData">
                        <i class="bi bi-x-circle"></i> Limpar os Dados do Formulário
                    </button>

                    <!-- Adicionar -->
                    <button type="submit" class="btn btn-primary">
                        Adicionar
                    </button>
                </div>
            </EditForm>
        </div>
    </div>
</div>

<InfoModal Message="@_message" Success="@_success" />

@code {
    private Book _book = new();
    private string? _message;
    private bool _success;

    /// <summary>
    /// Método para submeter os dados do formulário de adição de um livro ao catálogo.
    /// Ele tenta adicionar o livro usando a operação fornecida e captura quaisquer erros que possam ocorrer,
    /// exibindo mensagens apropriadas para o usuário.
    /// </summary>
    private async Task SubmitAddBook()
    {
        try
        {
            await Operation.AddBookAsync(_book);

            _message = "Adicionado!";
            _success = true;
        }
        catch (InvalidOperationException error)
        {
            _message = $"{error.Message}";
            _success = false;
        }
        catch (Exception error)
        {
            _message = $"Erro ao adicionar o livro  {_book.Title} ao Catálogo." +
                       $"\n Erro: {error.Message}";
            _success = false;
        }
        finally
        {
            StateHasChanged();
            _message = string.Empty;
        }    
    }
    
    /// <summary>
    /// Método para limpar os dados do formulário,
    /// resetando o modelo do livro para um novo objeto vazio e atualizando a interface do usuário.
    /// </summary>
    private void ClearFormData()
    {
        _book = new Book();
        StateHasChanged();
    }
}